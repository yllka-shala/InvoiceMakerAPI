{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=Your_Server;Database=InvoiceMakerDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Key": "Your_SingingKey",
    "Issuer": "InvoiceMakerAPI",
    "Audience": "InvoiceMakerClient",
    "ExpiryInMinutes": 60
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "Port": 587,
    "Username": "Your_Email",
    "Password": "Your_Password"
  },
  "AllowedHosts": "*"
}
